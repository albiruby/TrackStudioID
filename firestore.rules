rules_version = '2';
// PRODUCT LAW COMPLIANCE:
// 1. All private connection tokens (accessToken, refreshToken, apiKey, clientSecret) 
//    are isolated in users/{userId}/privateConnections/{document=**} and are completely 
//    BLOCKED from client access.
// 2. Safe connection metadata is exposed in users/{userId}/connections/{document=**}
//    with strict field rules actively blocking clients from injecting secrets.
// 3. Fake AI or fabricated tracking telemetry is prevented.
// 4. Source faking is prevented for strava/intervals, only server can write it.
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper to check for secrets being written
    function isNotWritingSecrets() {
      let data = request.resource.data;
      return !('accessToken' in data) &&
             !('refreshToken' in data) &&
             !('apiKey' in data) &&
             !('clientSecret' in data) &&
             !('secrets' in data);
    }

    // Helper to check source fields for create
    function isNotFakingCreateSource() {
      let data = request.resource.data;
      return !('source' in data) || (data.source != 'strava' && data.source != 'intervals');
    }

    // Helper to check source fields for update
    function isNotFakingUpdateSource() {
      let data = request.resource.data;
      return !('source' in data) || (data.source == resource.data.source) || (data.source != 'strava' && data.source != 'intervals');
    }

    // 1. Global Safety Net - Default Deny Everything
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. User & Athlete Profile Rules
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create, update: if request.auth != null && request.auth.uid == userId && isNotWritingSecrets();
      allow delete: if request.auth != null && request.auth.uid == userId;

      // Athlete Profile Subcollection
      match /profile/{profileId} {
        allow read, write: if request.auth != null && request.auth.uid == userId && isNotWritingSecrets();
      }

      // Activity Streams (Nested Subcollection)
      match /activityStreams/{activityId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null && request.auth.uid == userId && isNotFakingCreateSource();
        allow update: if request.auth != null && request.auth.uid == userId && isNotFakingUpdateSource();
        allow delete: if request.auth != null && request.auth.uid == userId;
      }

      // Connections (Public status)
      match /connections/{connectionId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create, update: if request.auth != null && request.auth.uid == userId && isNotWritingSecrets();
        allow delete: if request.auth != null && request.auth.uid == userId;
      }

      // Private Connections (Nested Subcollection - Tokens)
      match /privateConnections/{connectionId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Activities
      match /activities/{activityId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null && request.auth.uid == userId && isNotFakingCreateSource();
        allow update: if request.auth != null && request.auth.uid == userId && isNotFakingUpdateSource();
        allow delete: if request.auth != null && request.auth.uid == userId;
      }

      // Daily Wellness Logs (Nested Subcollection)
      match /wellnessLogs/{date} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null && request.auth.uid == userId && isNotFakingCreateSource();
        allow update: if request.auth != null && request.auth.uid == userId && isNotFakingUpdateSource();
        allow delete: if request.auth != null && request.auth.uid == userId;
      }

      // Daily Loads (Nested Subcollection)
      match /dailyLoad/{date} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null && request.auth.uid == userId && isNotFakingCreateSource();
        allow update: if request.auth != null && request.auth.uid == userId && isNotFakingUpdateSource();
        allow delete: if request.auth != null && request.auth.uid == userId;
      }

      // All other nested subcollections fallback
      match /{otherSubcollections}/{docId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create, update: if request.auth != null && request.auth.uid == userId && isNotWritingSecrets();
        allow delete: if request.auth != null && request.auth.uid == userId;
      }
    }

    match /trainingLoads/{loadId} {
      allow read: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid && isNotFakingCreateSource();
      allow update: if request.auth != null && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid && isNotFakingUpdateSource();
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
  }
}
